{
  "name": "@itkmoon/mysql-mcp",
  "version": "1.0.0",
  "description": "A powerful MCP tool for MySQL database operations with stdio and HTTP/SSE transport support",
  "main": "dist/index.js",
  "bin": {
    "mysql-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "start:http": "node dist/index.js --http",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mysql",
    "database",
    "ai",
    "claude",
    "cursor",
    "trae",
    "model-context-protocol"
  ],
  "author": "ITKMUnigle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ITKMUnigle/MySQL-MCP-Tool.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mysql2": "^3.9.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  }
}
