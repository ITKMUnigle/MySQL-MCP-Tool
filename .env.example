# MySQL MCP Tool - Environment Configuration

# Transport mode: 'stdio' or 'http'
MCP_TRANSPORT=stdio

# HTTP server port (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=3000

# MySQL Connection Settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root

# Optional: Default database to use
# MYSQL_DATABASE=mydb

# Enable write operations (INSERT, UPDATE, DELETE, CREATE, DROP, etc.)
# Default: false (read-only mode)
MYSQL_ALLOW_WRITE=false
